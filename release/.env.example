# ============================================
# 归源 - 族谱管理系统 Docker 部署环境变量
# ============================================
# 复制此文件为 release/.env 并按需修改：
#   Copy-Item release/.env.example release/.env
# ============================================

# -------- MySQL 数据库配置 --------
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=genealogy
MYSQL_USER=genealogy
MYSQL_PASSWORD=genealogy

# -------- JWT 签名密钥 --------
# 至少 32 个字符，建议使用 64 位 hex：
# 生成方式: powershell -Command "-join ((0..31)|%%{'{0:x}' -f (Get-Random -Max 16)})"
JWT_SECRET=change-me-to-at-least-32-characters

# -------- CORS 跨域配置 --------
# 生产环境请改为你的实际域名，多个域名用逗号分隔
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

# -------- 镜像部署配置（可选）--------
# 仅当使用 release/docker-compose.deploy.yml 时需要
BACKEND_IMAGE=your-registry/guiyuan-backend:latest
FRONTEND_IMAGE=your-registry/guiyuan-frontend:latest

# -------- 数据库连接覆盖（可选）--------
# 不设置则后端默认连接本地开发地址；Docker compose 会在容器中注入 DB_URL
# DB_URL=jdbc:mysql://db:3306/genealogy?useUnicode=true&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai

# -------- JVM 内存配置（可选）--------
# 不设置则使用默认值 -Xms256m -Xmx512m
# JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC
