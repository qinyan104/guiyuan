    "html-to-image": "^1.11.13",
    "pdfjs-dist": "^5.7.284",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.6",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.0.11",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.0"
