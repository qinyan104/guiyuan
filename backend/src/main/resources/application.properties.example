spring.application.name=genealogy-server
server.port=8080

# MySQL Database Configuration
# Set DB_USERNAME, DB_PASSWORD, and JWT_SECRET environment variables.
# For local development, copy backend/.env.example to backend/.env.local and load those values in your shell or IDE.
spring.datasource.url=${DB_URL:jdbc:mysql://localhost:3306/genealogy?useUnicode=true&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai}
spring.datasource.username=${DB_USERNAME:root}
spring.datasource.password=${DB_PASSWORD:}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA Configuration
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect

# File Upload Configuration
spring.servlet.multipart.max-file-size=100MB
spring.servlet.multipart.max-request-size=100MB

# Server Size Limits
server.tomcat.max-swallow-size=100MB
server.tomcat.max-http-form-post-size=100MB
spring.codec.max-in-memory-size=100MB
server.max-http-header-size=64KB

# JWT Configuration
# IMPORTANT: Set JWT_SECRET environment variable in production. Without it, the app will fail to start.
app.jwt.secret=${JWT_SECRET:}
app.jwt.access-token-ttl=900000
app.jwt.refresh-token-ttl=2592000000

# CORS Configuration
app.cors.allowed-origins=${APP_CORS_ALLOWED_ORIGINS:http://localhost:5173}

# Cookie Security (set true in production with HTTPS)
app.secure-cookie=false

# Upload Directory
app.upload.dir=uploads
